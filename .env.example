# =============================================================================
# Genesis Edge Node — Environment Variable Placeholders
# =============================================================================
# Copy this file to .env and replace every CHANGE_ME value before deploying.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Global
# ---------------------------------------------------------------------------
# CHANGE_ME: replace with the actual FQDN of this edge node
EDGE_DOMAIN=CHANGE_ME

# ---------------------------------------------------------------------------
# Ingress — Traefik
# ---------------------------------------------------------------------------
# CHANGE_ME: replace with the real email for Let's Encrypt ACME registration
ACME_EMAIL=CHANGE_ME
TRAEFIK_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Telemetry — Vector
# ---------------------------------------------------------------------------
VECTOR_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Observability — Prometheus
# ---------------------------------------------------------------------------
# How long Prometheus retains time-series data (e.g. 15d, 30d)
PROMETHEUS_RETENTION=15d

# ---------------------------------------------------------------------------
# Observability — Grafana
# ---------------------------------------------------------------------------
GF_ADMIN_USER=admin
# CHANGE_ME: strong password for the Grafana admin account
GF_ADMIN_PASSWORD=CHANGE_ME
# CHANGE_ME: random 64-char hex string used for signing Grafana sessions
GF_SECRET_KEY=CHANGE_ME
# OAuth client credentials registered in Dex for Grafana
GRAFANA_OAUTH_CLIENT_ID=grafana
# CHANGE_ME: must match the clientSecret in config/dex/config.yaml
GRAFANA_OAUTH_CLIENT_SECRET=CHANGE_ME

# ---------------------------------------------------------------------------
# Security — HashiCorp Vault
# ---------------------------------------------------------------------------
VAULT_LOG_LEVEL=info
# Seal type: shamir (default) or awskms / gcpckms / azurekeyvault for auto-unseal
VAULT_SEAL_TYPE=shamir

# ---------------------------------------------------------------------------
# Identity Management — Dex OIDC
# ---------------------------------------------------------------------------
DEX_CLIENT_ID=edge-node
# CHANGE_ME: shared secret between Dex and downstream OAuth2 clients
DEX_CLIENT_SECRET=CHANGE_ME
# Storage backend for Dex: sqlite3 (dev) or postgres (production)
DEX_STORAGE_TYPE=sqlite3

# Optional LDAP connector (leave blank to disable)
DEX_LDAP_HOST=
DEX_LDAP_BIND_DN=
# CHANGE_ME: LDAP bind password — only required when DEX_LDAP_HOST is set
DEX_LDAP_BIND_PW=CHANGE_ME

# ---------------------------------------------------------------------------
# Policy Enforcement — Open Policy Agent
# ---------------------------------------------------------------------------
OPA_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Ledger — Hyperledger Besu
# ---------------------------------------------------------------------------
# Network preset: dev | mainnet | goerli | sepolia — or omit for genesis file
BESU_NETWORK=dev
# External P2P advertise address
BESU_P2P_HOST=0.0.0.0
BESU_P2P_PORT=30303
# Comma-separated enode URLs of bootstrap peers (leave blank for dev mode)
BESU_BOOTNODES=
# Enable miner (IBFT2 / Clique networks only)
BESU_MINER_ENABLED=false
# CHANGE_ME: Ethereum address that receives block rewards when mining is enabled
BESU_MINER_COINBASE=CHANGE_ME
# Allowed CORS origins for the RPC HTTP endpoint (none | * | https://app.example.com)
BESU_RPC_CORS_ORIGINS=none
BESU_PERMISSIONS_ENABLED=false
BESU_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Settlement — Stellar Quickstart
# ---------------------------------------------------------------------------
# Network to connect to: testnet | mainnet | futurenet
SETTLEMENT_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# CHANGE_ME: Stellar secret seed (S...) for the settlement signing account
SETTLEMENT_ACCOUNT_SEED=CHANGE_ME
# CHANGE_ME: API key used to authenticate requests to the settlement service
SETTLEMENT_API_KEY=CHANGE_ME
SETTLEMENT_LOG_LEVEL=info
